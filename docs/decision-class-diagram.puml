@startuml
' PHPDecide - Diagram 1/2
' Domain model + Explain + CLI

skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam linetype ortho
left to right direction

set namespaceSeparator ::

title PHPDecide - Domain and CLI (src)

package PhpDecide::Config {
  class PhpDecideDefaults
}

package Symfony::Console {
  abstract class Command <<Symfony>>
}

package Symfony::Yaml {
  class Yaml <<Symfony>>
  class ParseException <<Symfony>>
}

package PhpDecide::Decision {
  class Decision
  class DecisionId
  enum DecisionStatus
  class Scope
  enum ScopeType
  class DecisionContent
  class Examples
  class Rules
  class AiMetadata
  class References
  interface DecisionLoader
  class YamlDecisionLoader
  class DecisionFileCollector
  interface DecisionRepository
  interface SearchIndexedDecisionRepository
  class FileDecisionRepository
  class DecisionFactory
}

package PhpDecide::Explain {
  interface AiExplainer
  class AiClientExplainer
  class ExplainService
  class DecisionMatcher
  class Explanation
}

package PhpDecide::AI {
  interface AiClient <<external>>
  class AiClientFactory <<external>>
}

package PhpDecide::CLI {
  class ExplainCommand
  class DecisionsLintCommand
}

' --- Domain composition ---
Decision *-- "1" DecisionId : id
Decision *-- "1" DecisionContent : content
Decision *-- "1" Examples : examples
Decision *-- "1" Scope : scope
Decision --> "1" DecisionStatus : status
Decision o-- "0..1" Rules : rules
Decision o-- "0..1" AiMetadata : aiMetadata
Decision o-- "0..1" References : references
Scope --> "1" ScopeType : type

' --- Interfaces / implementations ---
YamlDecisionLoader ..|> DecisionLoader
FileDecisionRepository ..|> DecisionRepository
FileDecisionRepository ..|> SearchIndexedDecisionRepository
AiClientExplainer ..|> AiExplainer

' --- CLI inheritance ---
ExplainCommand --|> Command
DecisionsLintCommand --|> Command

' --- Dependencies ---
YamlDecisionLoader ..> DecisionFileCollector
FileDecisionRepository ..> DecisionLoader
FileDecisionRepository ..> Decision
FileDecisionRepository ..> DecisionId

DecisionFactory ..> Decision
DecisionFactory ..> DecisionId
DecisionFactory ..> DecisionStatus
DecisionFactory ..> Scope
DecisionFactory ..> ScopeType
DecisionFactory ..> DecisionContent
DecisionFactory ..> Examples
DecisionFactory ..> Rules
DecisionFactory ..> AiMetadata
DecisionFactory ..> References

ExplainService *-- DecisionMatcher
ExplainService ..> DecisionRepository
ExplainService ..> AiExplainer
DecisionMatcher ..> DecisionRepository
DecisionMatcher ..> SearchIndexedDecisionRepository
DecisionMatcher ..> Decision
Explanation o-- "0..*" Decision

AiClientExplainer ..> AiClient

ExplainCommand ..> PhpDecideDefaults
ExplainCommand ..> YamlDecisionLoader
ExplainCommand ..> FileDecisionRepository
ExplainCommand ..> ExplainService
ExplainCommand ..> AiClientFactory
ExplainCommand ..> AiClientExplainer

DecisionsLintCommand ..> PhpDecideDefaults
DecisionsLintCommand ..> DecisionFileCollector
DecisionsLintCommand ..> DecisionFactory
DecisionsLintCommand ..> Yaml
DecisionsLintCommand ..> ParseException

@enduml

@startuml
' PHPDecide - Diagram 2/2
' AI client + transport + egress guard

skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam linetype ortho
left to right direction

set namespaceSeparator ::

title PHPDecide - AI and Guard (src)

package PhpDecide::Decision {
  class Decision <<external>>
}

package PhpDecide::AI {
  interface AiClient
  class AiClientConfig
  class AiClientFactory
  class OpenAiChatCompletionsClient
  class DecisionPayloadNormalizer
  class ExplainPromptBuilder
  class AiClientException
}

package PhpDecide::AI::Http {
  interface HttpClient
  class HttpResponse
  class CurlHttpClient
}

package PhpDecide::AI::Guard {
  class EgressGuardAiClient
  class GuardPolicy
  class GuardPolicyFactory
  class DlpScanner
  class Finding
  interface AuditLogger
  class NullAuditLogger
  class StderrJsonAuditLogger
}

' --- Interfaces / implementations ---
OpenAiChatCompletionsClient ..|> AiClient
EgressGuardAiClient ..|> AiClient
CurlHttpClient ..|> HttpClient
NullAuditLogger ..|> AuditLogger
StderrJsonAuditLogger ..|> AuditLogger

' --- Composition ---
OpenAiChatCompletionsClient o-- "1" HttpClient : httpClient
EgressGuardAiClient o-- "1" AiClient : inner
EgressGuardAiClient o-- "1" GuardPolicy : policy
EgressGuardAiClient o-- "1" DlpScanner : dlpScanner
EgressGuardAiClient o-- "1" AuditLogger : auditLogger

' --- Dependencies ---
AiClientFactory ..> AiClientConfig
AiClientFactory ..> HttpClient
AiClientFactory ..> OpenAiChatCompletionsClient
AiClientFactory ..> GuardPolicyFactory
AiClientFactory ..> EgressGuardAiClient
AiClientFactory ..> StderrJsonAuditLogger
AiClientFactory ..> NullAuditLogger

CurlHttpClient ..> HttpResponse

OpenAiChatCompletionsClient ..> Decision
OpenAiChatCompletionsClient ..> DecisionPayloadNormalizer
OpenAiChatCompletionsClient ..> ExplainPromptBuilder
OpenAiChatCompletionsClient ..> AiClientException

EgressGuardAiClient ..> DecisionPayloadNormalizer
EgressGuardAiClient ..> ExplainPromptBuilder
EgressGuardAiClient ..> AiClientException
EgressGuardAiClient ..> Decision
GuardPolicyFactory ..> GuardPolicy
DlpScanner ..> Finding

@enduml
